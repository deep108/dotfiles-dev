#!/bin/zsh
# Install Ruby (via mise) and the Kamal deploy CLI (Linux guest only).
# Uses mise CLI commands so it adds to whatever's already in the global
# config (e.g. Java for Android) rather than clobbering it.

set -euo pipefail

{{ if ne .chezmoi.os "linux" -}}
# macOS guests can't run Docker for deploys, so we skip Kamal there.
exit 0
{{ end -}}

{{ if ne .host_type "guest" -}}
# Hosts don't deploy.
exit 0
{{ end -}}

eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"

RUBY_VERSION="3.4"
KAMAL_VERSION="2.11.0"

if ! command -v mise &>/dev/null; then
    echo "⚠ mise not found — skipping Ruby/Kamal install"
    exit 0
fi

# Opt into precompiled Ruby binaries (becomes default in mise 2026.8.0).
# Using `mise settings set` rather than writing to a TOML file so we don't
# care about the exact storage format mise uses.
mise settings set ruby.compile false

# Add ruby to the global mise config (additive — preserves existing entries
# like Java) and install it. `mise use -g` triggers install if not present.
mise use -g "ruby@${RUBY_VERSION}"

# Check if kamal is already installed at the pinned version
if command -v kamal &>/dev/null; then
    current=$(kamal version 2>/dev/null || echo "")
    if [[ "$current" == "$KAMAL_VERSION" ]]; then
        echo "✓ Kamal $current"
        exit 0
    fi
fi

echo "Installing Kamal $KAMAL_VERSION..."
for attempt in 1 2 3; do
    if mise exec ruby -- gem install --user-install kamal -v "$KAMAL_VERSION"; then
        break
    fi
    echo "  Attempt $attempt failed, retrying..."
    sleep 2
done

if command -v kamal &>/dev/null; then
    echo "✓ Kamal $(kamal version 2>/dev/null)"
else
    echo "⚠ Kamal not on PATH — verify ~/.gem/.../bin is in zprofile (run: exec zsh -l)"
fi
