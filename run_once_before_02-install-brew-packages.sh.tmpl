#!/bin/zsh
# Install dev tools via Homebrew
# macOS: assumes brew and chezmoi already installed via bootstrap.sh
# Linux: assumes brew and chezmoi already installed via bootstrap-linux.sh

set -euo pipefail

{{ if eq .chezmoi.os "darwin" -}}
eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv 2>/dev/null)"
{{ else if eq .chezmoi.os "linux" -}}
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{ end -}}

install_if_missing() {
    local cmd="$1"
    local pkg="${2:-$1}"
    if ! command -v "$cmd" &>/dev/null; then
        echo "Installing $pkg..."
        brew install "$pkg"
    fi
}

# Install via brew even if an OS version exists (brew PATH takes precedence)
install_or_upgrade() {
    local pkg="$1"
    if ! brew list "$pkg" &>/dev/null; then
        echo "Installing $pkg..."
        brew install "$pkg"
    fi
}

{{ if eq .chezmoi.os "darwin" -}}
install_cask_if_missing() {
    local app_name="$1"
    local cask="$2"
    if ! [ -d "/Applications/${app_name}.app" ] && ! [ -d "$HOME/Applications/${app_name}.app" ]; then
        echo "Installing $cask..."
        brew install --cask "$cask"
    fi
}

install_font_if_missing() {
    local font_file="$1"
    local cask="$2"
    if ! [ -f "$HOME/Library/Fonts/${font_file}" ] && ! [ -f "/Library/Fonts/${font_file}" ]; then
        echo "Installing $cask..."
        brew install --cask "$cask"
    fi
}

{{ if eq .host_type "host" -}}
# Host packages
install_if_missing nvim neovim
install_if_missing openssl
install_if_missing starship
install_if_missing tart
install_if_missing tmux
install_if_missing git-credential-manager
install_cask_if_missing "Google Chrome" google-chrome
install_cask_if_missing "iTerm" iterm2
install_font_if_missing "MesloLGMDZNerdFont-Regular.ttf" font-meslo-lg-nerd-font
{{ else -}}
# Guest packages (formulae)
install_if_missing mise
install_if_missing starship
install_if_missing tmux
install_if_missing nvim neovim
install_if_missing jq
install_if_missing wget
install_if_missing tree
install_if_missing htop
install_if_missing watch
# Brew over OS — install newer versions than macOS ships
install_or_upgrade curl
install_or_upgrade openssl
install_or_upgrade git
install_or_upgrade rsync
install_or_upgrade zip
install_or_upgrade unzip
# Guest packages (casks — macOS only)
install_cask_if_missing "Visual Studio Code" visual-studio-code
install_cask_if_missing "iTerm" iterm2
install_font_if_missing "MesloLGMDZNerdFont-Regular.ttf" font-meslo-lg-nerd-font
{{ end -}}
{{ else if eq .chezmoi.os "linux" -}}
# Guest packages (same brew formulae as macOS guest)
install_if_missing mise
install_if_missing starship
install_if_missing tmux
install_if_missing nvim neovim
install_if_missing jq
install_if_missing wget
install_if_missing tree
install_if_missing htop
install_if_missing watch
# Brew over OS — install newer versions than Debian ships
install_or_upgrade curl
install_or_upgrade openssl
install_or_upgrade git
install_or_upgrade rsync
install_or_upgrade zip
install_or_upgrade unzip

# VS Code from Microsoft's apt repo (Homebrew casks are macOS-only)
if ! command -v code &>/dev/null; then
    echo "Installing VS Code..."
    wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor | sudo tee /usr/share/keyrings/packages.microsoft.gpg > /dev/null
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/packages.microsoft.gpg] https://packages.microsoft.com/repos/code stable main" | sudo tee /etc/apt/sources.list.d/vscode.list > /dev/null
    sudo apt-get update -qq
    sudo apt-get install -y -qq code
fi
{{ end -}}

# Verify mise installation
if command -v mise &>/dev/null; then
    echo "mise $(mise --version 2>/dev/null | awk '{print $1}')"
fi

echo "✓ Brew packages installed"
