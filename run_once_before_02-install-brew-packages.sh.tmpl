#!/bin/zsh
# Install dev tools
# macOS: via Homebrew (assumes brew and chezmoi already installed via bootstrap.sh)
# Linux: via apt + curl installers (assumes apt packages installed via bootstrap-linux.sh)

set -euo pipefail

{{ if eq .chezmoi.os "linux" -}}
# --- Linux (Debian) ---

install_if_missing() {
    local cmd="$1"
    local pkg="${2:-$1}"
    if ! command -v "$cmd" &>/dev/null; then
        echo "Installing $pkg..."
        sudo apt-get install -y -qq "$pkg"
    fi
}

# Packages available via apt
install_if_missing tmux
install_if_missing nvim neovim

# starship (not in Debian repos — installed by bootstrap-linux.sh to /usr/local/bin)
if ! command -v starship &>/dev/null; then
    echo "Installing starship..."
    curl -sS https://starship.rs/install.sh | sudo sh -s -- -y
fi

# mise (not in Debian repos — use official installer)
if ! command -v mise &>/dev/null; then
    echo "Installing mise..."
    curl https://mise.run | sh
fi

echo "✓ Linux packages installed"
{{ else -}}
# --- macOS ---

eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv 2>/dev/null)"

install_if_missing() {
    local cmd="$1"
    local pkg="${2:-$1}"
    if ! command -v "$cmd" &>/dev/null; then
        echo "Installing $pkg..."
        brew install "$pkg"
    fi
}

install_cask_if_missing() {
    local app_name="$1"
    local cask="$2"
    if ! [ -d "/Applications/${app_name}.app" ] && ! [ -d "$HOME/Applications/${app_name}.app" ]; then
        echo "Installing $cask..."
        brew install --cask "$cask"
    fi
}

install_font_if_missing() {
    local font_file="$1"
    local cask="$2"
    if ! [ -f "$HOME/Library/Fonts/${font_file}" ] && ! [ -f "/Library/Fonts/${font_file}" ]; then
        echo "Installing $cask..."
        brew install --cask "$cask"
    fi
}

{{ if eq .host_type "host" -}}
# Host packages
install_if_missing nvim neovim
install_if_missing openssl
install_if_missing starship
install_if_missing tart
install_if_missing tmux
install_if_missing git-credential-manager
install_cask_if_missing "Google Chrome" google-chrome
install_cask_if_missing "iTerm" iterm2
install_font_if_missing "MesloLGMDZNerdFont-Regular.ttf" font-meslo-lg-nerd-font
{{ else -}}
# Guest packages
install_if_missing mise
install_if_missing starship
install_if_missing tmux
install_if_missing nvim neovim
install_cask_if_missing "Visual Studio Code" visual-studio-code
install_cask_if_missing "iTerm" iterm2
install_font_if_missing "MesloLGMDZNerdFont-Regular.ttf" font-meslo-lg-nerd-font
{{ end -}}

echo "✓ Brew packages installed"
{{ end -}}
