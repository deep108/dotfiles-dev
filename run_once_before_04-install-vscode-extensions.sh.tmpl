#!/bin/zsh
# Install VS Code extensions (guest VMs only)

set -euo pipefail

{{ if eq .host_type "guest" -}}
{{ if eq .chezmoi.os "darwin" -}}
eval "$(/opt/homebrew/bin/brew shellenv 2>/dev/null || /usr/local/bin/brew shellenv 2>/dev/null)"
{{ end -}}

if ! command -v code &>/dev/null; then
    echo "✗ VS Code not found — skipping extensions"
    exit 0
fi

extensions=(
    ms-vscode.cpptools
    anthropics.claude-code
    monokai.theme-monokai-pro-vscode
    johnpapa.vscode-peacock
    esbenp.prettier-vscode
    asvetliakov.vscode-neovim
    github.copilot
    github.copilot-chat
)

for ext in "${extensions[@]}"; do
    if ! code --list-extensions 2>/dev/null | grep -qix "$ext"; then
        echo "Installing extension: $ext..."
        code --install-extension "$ext" --force 2>/dev/null || echo "  Warning: failed to install $ext"
    fi
done

echo "✓ VS Code extensions installed"
{{ else -}}
# Host — no VS Code extensions to install
{{ end -}}
